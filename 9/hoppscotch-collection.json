          "body": {
            "contentType": "application/json",
            "body": "{\n  \"title\": \"My first task\",\n  \"description\": \"This is a test task\",\n  \"dueDate\": \"2026-12-31T23:59:00.000Z\"\n}"
          },
          "preRequestScript": "",
          "testScript": "pw.test(\"Status is 201\", () => {\n  pw.expect(pw.response.status).toBe(201);\n});\npw.test(\"Response has id\", () => {\n  pw.expect(pw.response.body).toHaveProperty(\"id\");\n});\npw.test(\"Title matches\", () => {\n  pw.expect(pw.response.body.title).toBe(\"My first task\");\n});\npw.test(\"completedAt is null\", () => {\n  pw.expect(pw.response.body.completedAt).toBeNull();\n});\npw.env.set(\"id\", pw.response.body.id);",
          "requestVariables": []
        },
        {
          "v": "3",
          "id": "tasks-get-all",
