    {
      "v": 2,
      "name": "1 - Login",
      "folders": [],
      "requests": [
        {
          "v": "3",
          "id": "auth-login",
          "name": "Login",
          "method": "POST",
          "endpoint": "http://localhost:3000/login",
          "headers": [
            { "key": "Content-Type", "value": "application/json", "active": true, "description": "" }
          ],
          "params": [],
          "auth": { "authType": "none", "authActive": false },
          "body": {
            "contentType": "application/json",
            "body": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
          },
          "preRequestScript": "",
          "testScript": "pw.test(\"Status is 200\", () => {\n  pw.expect(pw.response.status).toBe(200);\n});\npw.test(\"Response has token\", () => {\n  pw.expect(pw.response.body).toHaveProperty(\"token\");\n});\npw.env.set(\"token\", pw.response.body.token);",
          "requestVariables": []
        }
      ]
    },
    {
