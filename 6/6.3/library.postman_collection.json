{
  "info": {
    "name": "Library API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Books",
      "item": [
        {
          "name": "[Schönwetter] GET /books",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/books"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Array has entries', () => pm.expect(pm.response.json().length).to.be.above(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] GET /books/1",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/books/1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Returns correct book', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.isbn).to.eql(1);",
                  "  pm.expect(body).to.have.property('title');",
                  "  pm.expect(body).to.have.property('author');",
                  "  pm.expect(body).to.have.property('year');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] POST /books",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/books",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"isbn\": 99, \"title\": \"Test Book\", \"author\": \"Test Author\", \"year\": 2024 }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Returns created book', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.isbn).to.eql(99);",
                  "  pm.expect(body.title).to.eql('Test Book');",
                  "  pm.expect(body.author).to.eql('Test Author');",
                  "  pm.expect(body.year).to.eql(2024);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] PUT /books/99",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/books/99",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"title\": \"Updated Book\", \"author\": \"Updated Author\", \"year\": 2025 }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Book is fully replaced', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.isbn).to.eql(99);",
                  "  pm.expect(body.title).to.eql('Updated Book');",
                  "  pm.expect(body.year).to.eql(2025);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] PATCH /books/99",
          "request": {
            "method": "PATCH",
            "url": "http://localhost:3000/books/99",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"year\": 2026 }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Only year is updated, other fields unchanged', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.isbn).to.eql(99);",
                  "  pm.expect(body.year).to.eql(2026);",
                  "  pm.expect(body.title).to.eql('Updated Book');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] DELETE /books/99",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/books/99"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Returns remaining books array', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "[Fehler] POST /books - Buch ohne Titel",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/books",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"isbn\": 50, \"author\": \"Someone\", \"year\": 2024 }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
