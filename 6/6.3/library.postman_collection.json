                  "pm.test('Returns error message', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Lends",
      "item": [
        {
          "name": "[Schönwetter] POST /lends",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/lends",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"customerId\": 1, \"isbn\": 1 }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Returns lend object with correct fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body.customerId).to.eql(1);",
                  "  pm.expect(body.isbn).to.eql(1);",
                  "  pm.expect(body).to.have.property('borrowedAt');",
                  "  pm.expect(body.returnedAt).to.be.null;",
                  "});",
                  "pm.collectionVariables.set('lendId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] GET /lends",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/lends"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Array has entries', () => pm.expect(pm.response.json().length).to.be.above(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] GET /lends/:id",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/lends/{{lendId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('Returns correct lend', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.eql(pm.collectionVariables.get('lendId'));",
                  "  pm.expect(body).to.have.property('borrowedAt');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "[Schönwetter] DELETE /lends/:id",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/lends/{{lendId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('returnedAt is set', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.returnedAt).to.not.be.null;",
                  "  pm.expect(body.returnedAt).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
