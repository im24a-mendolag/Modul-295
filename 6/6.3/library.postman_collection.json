        {
          "name": "[Fehler] POST /lends - Fehlende Felder (422)",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/lends",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
